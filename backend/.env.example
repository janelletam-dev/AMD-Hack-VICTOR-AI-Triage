# V.I.C.T.O.R. backend — copy to .env and fill in.
# Never commit .env (it's in .gitignore).

# --- Deepgram (STT) ---------------------------------------------------------
DEEPGRAM_API_KEY=

# --- Thymia (voice biomarkers) ---------------------------------------------
THYMIA_API_KEY=
THYMIA_POLICY=demo_wellbeing_awareness
THYMIA_BIOMARKERS=helios,apollo

# --- LLM endpoint (Ollama locally, vLLM on MI300X) -------------------------
# Default points at Ollama. Swap base_url + model to use vLLM on the MI300X
# droplet. Both speak the OpenAI /v1 chat/completions format, so no code change.
VLLM_BASE_URL=http://localhost:11434/v1
VLLM_MODEL=llama3.1:8b
VLLM_API_KEY=ollama-local

# --- ElevenLabs (TTS) -------------------------------------------------------
ELEVENLABS_API_KEY=
# Voice IDs from your ElevenLabs library — Victor (calm) + Jackie (warm).
ELEVENLABS_VOICE_VICTOR=
ELEVENLABS_VOICE_JACKIE=

# --- App --------------------------------------------------------------------
SESSION_SECRET=dev-secret-change-me
NODE_ENV=development
