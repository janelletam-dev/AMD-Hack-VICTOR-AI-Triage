# V.I.C.T.O.R. backend — copy to .env and fill in.
# Never commit .env (it's in .gitignore).

# --- Deepgram (STT) ---------------------------------------------------------
DEEPGRAM_API_KEY=

# --- Thymia (voice biomarkers) ---------------------------------------------
THYMIA_API_KEY=
THYMIA_POLICY=demo_wellbeing_awareness
THYMIA_BIOMARKERS=helios,apollo

# --- LLM endpoint (Ollama locally, vLLM on MI300X) -------------------------
# Default points at Ollama. Swap base_url + model to use vLLM on the MI300X
# droplet. Both speak the OpenAI /v1 chat/completions format, so no code change.
VLLM_BASE_URL=http://localhost:11434/v1
VLLM_MODEL=llama3.1:8b
VLLM_API_KEY=ollama-local

# --- ElevenLabs (TTS) -------------------------------------------------------
ELEVENLABS_API_KEY=
# Voice IDs from your ElevenLabs library — Victor (calm) + Jackie (warm).
ELEVENLABS_VOICE_VICTOR=
ELEVENLABS_VOICE_JACKIE=

# --- App --------------------------------------------------------------------
SESSION_SECRET=dev-secret-change-me
# In production set NODE_ENV=production. The backend logs an error at startup
# if DEMO_MODE=true and NODE_ENV=production (Thymia output would be fake).
NODE_ENV=development

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed frontend origins. Must NOT contain "*" — the
# combo of wildcard origin + credentials is rejected by browsers. Default
# permits localhost dev. In production, set to your real frontend hostnames.
# Example: VICTOR_ALLOWED_ORIGINS=https://victor.example.com,https://kiosk.example.com
VICTOR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Demo mode --------------------------------------------------------------
# Set to true on hackathon demo day. Bypasses live Thymia output and substitutes
# scripted biomarker values (stress 0.66, distress 0.66, mentalStrain 0.68,
# exhaustion 0.33) so the concordance flag fires reliably regardless of how
# the demoer actually sounds. Real Thymia API is NOT called when set.
# Leave false in production.
DEMO_MODE=false
