# Frontend production env vars — copy to .env.production before `npm run build`
# Vite substitutes any `import.meta.env.VITE_*` references in source at build
# time using these values. The fallbacks in code default to localhost, which
# would break a deployed site.
#
# Both URLs MUST use TLS (https/wss) in production. Browsers refuse to grant
# microphone permission to non-HTTPS pages, which would silently break the
# patient kiosk.

VITE_BACKEND_HTTP_URL=https://api.victor.example.com
VITE_BACKEND_WS_URL=wss://api.victor.example.com
